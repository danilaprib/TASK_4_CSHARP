<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TASK_4_CSHARP</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TASK_4_CSHARP.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: #446ce6;">
            <div class="container-fluid">
                <div class="navbar-collapse collapse w-100 order-1 order-sm-0">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="navbar-brand" asp-page="/Index">Task 4</a>
                        </li>
                        <li>
                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    @TempData["SuccessMessage"]
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }
                            @if (TempData["ErrorMessage"] != null)
                            {
                                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                    @TempData["ErrorMessage"]
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }
                        </li>
                    </ul>

                </div>

                <div class="mx-auto order-0">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-white fw-bold" asp-page="/Index">Dashboard</a>
                        </li>
                    </ul>
                </div>

                <div class="navbar-collapse collapse w-100 order-3">
                    <ul class="navbar-nav ms-auto d-flex align-items-center gap-3">
                        <li class="nav-item">
                            <span class="navbar-text text-white">
                                @if (Context != null && Context.User.Identity.IsAuthenticated)
                                {
                                    <i class="fa-solid fa-user me-1">@User.Identity.Name</i>                                    
                                }
                            </span>
                        </li>
                        <li class="nav-item">
                            @if (Context != null && Context.User.Identity.IsAuthenticated)
                            {
                                <a class="btn btn-outline-light btn-sm" asp-page="/Logout">Logout</a>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-sm" asp-page="/Login">Login</a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-white" style="background-color: #446ce6;">
        <div class="container">
            &copy; Copyright 2026 TASK_4_CSHARP Daniil Prybyshchuk
        </div>
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>


    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
