@page
@model TASK_4_CSHARP.Pages.SignUpModel
@{
    ViewData["Title"] = "Sign Up page";
}



<div>
    <form class="gap-3 d-flex flex-column" method="post">
        <h1>Sign Up</h1>
        <div class="form-group">
            <label for="usernameInput">Username</label>
            <input name="username" id="usernameInput" class="form-control" type="text" placeholder="Your username" />
        </div>
        <div class="form-group">
            <label for="emailInput">Email</label>
            <input name="email" id="emailInput" class="form-control" type="email" placeholder="john.doe@email.com" />
        </div>
        <div class="form-group">
            <label for="passwordInput">Password</label>
            <input name="password" id="passwordInput" class="form-control" type="password" placeholder="Your Password" />
        </div>
        <button type="submit" class="btn btn-primary">Register</button>

    </form>
</div>
